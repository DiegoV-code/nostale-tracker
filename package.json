{
  "name": "nostale-tracker",
  "version": "4.11.0",
  "description": "Nostale Market Price Tracker",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "release": "npm run build && electron-builder --publish always",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.nostale.tracker",
    "productName": "Nostale Tracker",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "allowElevation": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DiegoV-code",
        "repo": "nostale-tracker",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.22",
    "electron-updater": "^6.8.3",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.0",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.0"
  }
}
